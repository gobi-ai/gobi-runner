# ── Required (all modes) ──────────────────────────────────────
LINEAR_API_KEY=lin_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RUNNER_PASSWORD=your-secure-password
LINEAR_WEBHOOK_SECRET=

# ── Optional (all modes) ──────────────────────────────────────
GITHUB_WEBHOOK_SECRET=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Docker-in-Docker mode ────────────────────────────────────
# Only needed when running the server itself in Docker
# (i.e. docker compose -f docker-compose.server.yml up)
# Not needed when running the server natively with npm start.
#
# All default to $HOME if not set.
HOST_PROJECTS_DIR=
HOST_HOME_DIR=
HOST_TEMP_DIR=/tmp/agent-runner
DOCKER_GID=999
